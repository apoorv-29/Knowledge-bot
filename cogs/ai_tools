# =========================================
# AI TOOLS COG
# =========================================

class AITools(commands.Cog):

    def __init__(self, bot):
        self.bot = bot

    # =====================================
    # EXPLAIN COMMAND
    # =====================================

    @commands.command()
    async def explain(self, ctx, *, topic=None):

        if not topic:

            return await ctx.send(
                "❌ Usage: `!explain api`"
            )

        topic = topic.lower()

        if topic not in EXPLANATIONS:

            return await ctx.send(
                "❌ No explanation available."
            )

        embed = discord.Embed(
            title=f"🧠 {topic.upper()}",
            description=EXPLANATIONS[topic],
            color=discord.Color.blue()
        )

        embed.set_footer(
            text="AI Knowledge Engine"
        )

        await ctx.send(embed=embed)

    # =====================================
    # DEBUG COMMAND
    # =====================================

    @commands.command()
    async def debug(self, ctx):

        tip = random.choice(DEBUGGING_TIPS)

        embed = discord.Embed(
            title="🛠 Debugging Tip",
            description=tip,
            color=discord.Color.orange()
        )

        await ctx.send(embed=embed)

    # =====================================
    # INTERVIEW COMMAND
    # =====================================

    @commands.command()
    async def interview(self, ctx):

        question = random.choice(
            INTERVIEW_QUESTIONS
        )

        embed = discord.Embed(
            title="💼 Interview Question",
            description=question,
            color=discord.Color.green()
        )

        await ctx.send(embed=embed)

    # =====================================
    # ASK COMMAND
    # =====================================

    @commands.command()
    async def ask(self, ctx, *, question=None):

        if not question:

            return await ctx.send(
                "❌ Usage: `!ask how does AI work?`"
            )

        responses = [

            "🤖 Interesting question. Research this deeply.",

            "🧠 Start by learning the fundamentals first.",

            "🚀 Build projects around this topic.",

            "📚 Combine theory with practical labs.",

            "💡 This topic is important in modern tech."
        ]

        embed = discord.Embed(
            title="🤖 AI Assistant",
            description=random.choice(responses),
            color=discord.Color.purple()
        )

        embed.add_field(
            name="❓ Your Question",
            value=question,
            inline=False
        )

        await ctx.send(embed=embed)

    # =====================================
    # TECHSTACK COMMAND
    # =====================================

    @commands.command()
    async def techstack(self, ctx):

        embed = discord.Embed(
            title="⚡ Recommended Tech Stack",
            description=(
                "🐍 Python\n"
                "🌐 FastAPI\n"
                "🗄 PostgreSQL\n"
                "🐳 Docker\n"
                "☁ Railway / AWS\n"
                "🤖 OpenAI / Groq APIs"
            ),
            color=discord.Color.teal()
        )

        await ctx.send(embed=embed)

    # =====================================
    # DEVOPS COMMAND
    # =====================================

    @commands.command()
    async def devops(self, ctx):

        embed = discord.Embed(
            title="🚀 DevOps Learning Path",
            description=(
                "1. Linux\n"
                "2. Docker\n"
                "3. GitHub Actions\n"
                "4. CI/CD\n"
                "5. Kubernetes\n"
                "6. Cloud Platforms"
            ),
            color=discord.Color.dark_blue()
        )

        await ctx.send(embed=embed)

# =========================================
# COG SETUP
# =========================================

async def setup(bot):
    await bot.add_cog(AITools(bot))
