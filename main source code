# --- HELPER FUNCTION ---
def get_contextual_topic(interaction: discord.Interaction):
    """Detects topic based on channel name or user roles."""
    channel_name = interaction.channel.name.lower()
    user_roles = [role.name.lower() for role in interaction.user.roles]
    
    if "cyber" in channel_name or "cybersecurity" in user_roles:
        return "cybersecurity"
    if "ai" in channel_name or "ml" in channel_name or "ai_ml" in user_roles:
        return "ai_ml"
    return None

# --- COMMANDS ---

@bot.tree.command(name="learn", description="Get a quick explanation and resources for a topic")
@app_commands.describe(topic="Specific topic (optional)")
async def learn(interaction: discord.Interaction, topic: str = None):
    # Detect topic if not provided
    selected_topic = topic.lower() if topic else get_contextual_topic(interaction)
    
    if not selected_topic or selected_topic not in DATA:
        return await interaction.response.send_message("❌ I couldn't find resources for that topic here. Try /learn cybersecurity", ephemeral=True)

    content = DATA[selected_topic]
    embed = discord.Embed(title=f"🎓 Learning: {selected_topic.upper()}", color=discord.Color.green())
    embed.add_field(name="Summary", value=content["explanation"], inline=False)
    embed.add_field(name="📺 Watch", value="\n".join(content["videos"]), inline=True)
    embed.add_field(name="📚 Read", value="\n".join(content["resources"]), inline=True)
    
    await interaction.response.send_message(embed=embed)

@bot.tree.command(name="roadmap", description="Get a step-by-step learning path")
async def roadmap(interaction: discord.Interaction):
    topic = get_contextual_topic(interaction)
    if not topic:
        return await interaction.response.send_message("I'm not sure which roadmap you need. Try this in a specific channel!", ephemeral=True)
    
    embed = discord.Embed(title=f"🗺️ {topic.upper()} Roadmap", description=DATA[topic]["roadmap"], color=discord.Color.blue())
    await interaction.response.send_message(embed=embed)

@bot.tree.command(name="resources", description="Quick links to top docs")
async def resources(interaction: discord.Interaction):
    topic = get_contextual_topic(interaction)
    if not topic:
        return await interaction.response.send_message("Use this in a niche channel (AI, Cyber) for better results!", ephemeral=True)
    
    links = "\n".join(DATA[topic]["resources"])
    await interaction.response.send_message(f"📚 **Top Resources for {topic.upper()}:**\n{links}")

@bot.event
async def on_ready():
    print(f"Logged in as {bot.user}")

bot.run(TOKEN)
